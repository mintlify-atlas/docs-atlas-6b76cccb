  "keyFeatures": [
    "Dynamic per-user flag generation (GUID, TEAM_HASH, LEET, CLEET types)",
    "Real-time leaderboard with score tracking",
    "Badge and achievement system",
    "Hint system with configurable point deductions",
    "Time-limited challenges with automatic expiry",
    "Google OAuth and NextAuth authentication",
    "Admin dashboard for challenge and user management",
    "Discord webhook notifications for new challenges",
    "AI chatbot integration for player support",
    "Blog/resources section via Notion CMS"
  ],
  "publicApiSurface": [
    "GET /api/problems - List challenges with pagination and category filter",
    "POST /api/problems - Create a new challenge (admin only)",
    "GET /api/problems/[id] - Get challenge details",
    "POST /api/problems/[id] - Submit a flag for a challenge",
    "POST /api/problems/dynamic-flag - Generate/retrieve a dynamic flag",
    "GET /api/problems/[id]/hints - Get hints for a challenge",
    "GET /api/leaderboard - Get leaderboard scores",
    "GET /api/profile - Get current user profile",
    "GET /api/user/[username] - Get public user profile",
    "GET /api/categories - List challenge categories",
    "GET /api/badge - Get badge information",
    "POST /api/admin/assign-badge - Assign a badge to a user",
    "GET /api/admin/dashboard-stats - Get admin dashboard statistics",
    "GET /api/admin/users - Manage users (admin only)"
  ]
